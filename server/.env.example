# MongoDB connection
MONGO_URI=mongodb://localhost:27017
DB_NAME=vibe_coding

# Collections (override only if your schema differs)
USERS_COLLECTION=users
LOGS_COLLECTION=logs
SESSIONS_COLLECTION=sessions

# Session token lifetime (minutes)
SESSION_TTL_MINUTES=5

# Server-side cache TTL for /api/chats, in seconds (authenticated users only)
CHATS_CACHE_TTL=60

# Flask
SECRET_KEY=change-me-in-production
PORT=5050

# Comma-separated list of allowed CORS origins (the Next.js UI)
CORS_ORIGINS=http://localhost:3000
