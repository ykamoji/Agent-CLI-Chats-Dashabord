# MongoDB connection
MONGO_URI=mongodb://localhost:27017
DB_NAME=vibe_coding

USERS_COLLECTION=users
LOGS_COLLECTION=logs
SESSIONS_COLLECTION=sessions
INSIGHTS_COLLECTION=insights

# Gemini (AI insights). Leave GOOGLE_API_KEY empty to run deterministic-only.
GOOGLE_API_KEY=
GOOGLE_MODEL_NAME=gemini-2.0-flash
# Conversations fed to the model and per-prompt truncation (token budget)
INSIGHTS_MAX_TURNS=60
INSIGHTS_INPUT_TRUNC=300
# Don't regenerate if a completed insight is newer than this (seconds), unless forced
INSIGHTS_MIN_REGEN_SECONDS=60

# Session token lifetime (minutes)
SESSION_TTL_MINUTES=15

# Server-side cache TTL for /api/chats, in seconds (authenticated users only)
CHATS_CACHE_TTL=60

# Flask
SECRET_KEY=change-me-in-production
PORT=5050

# Comma-separated list of allowed CORS origins (the Next.js UI)
CORS_ORIGINS=http://localhost:3000
